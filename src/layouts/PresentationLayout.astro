---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Taller Graphify — Presentación' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Taller práctico (90-120 min) para indexar un repo o /raw heterogéneo con Graphify, navegar el grafo vía skill, y decidir con criterio si adoptarlo. Por Código Sin Siesta." />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
